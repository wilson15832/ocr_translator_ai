<?xml version="1.0" encoding="utf-8"?>
<com.example.ocr_translation.GestureControlPanel xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/controlPanelRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="26dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/control_panel_background">

    <LinearLayout
        android:id="@+id/barContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btnAutoToggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:tint="#FFFFFFFF"
            android:src="@drawable/ic_start"
            android:contentDescription="@string/auto_mode" />

        <ImageButton
            android:id="@+id/btnTranslateNow"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:tint="#FFFFFFFF"
            android:src="@drawable/ic_translate"
            android:contentDescription="@string/translate_now" />

        <ImageButton
            android:id="@+id/btnSelectArea"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:tint="#FFFFFFFF"
            android:src="@drawable/ic_crop"
            android:contentDescription="@string/select_area" />

        <ImageButton
            android:id="@+id/btnFold"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:tint="#FFFFFFFF"
            android:src="@drawable/ic_collapse"
            android:contentDescription="@string/control_panel_collapse" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:tint="#FFFFFFFF"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close_translation" />
    </LinearLayout>
</com.example.ocr_translation.GestureControlPanel>